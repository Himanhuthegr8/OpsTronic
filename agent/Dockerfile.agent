# ============================================================================
# OpsTronic Agent Docker Image
# ============================================================================
# Minimal image that runs opstronic_forwarder.py on the user's machine.
# Users run this alongside their own services — it monitors Docker containers
# labeled with OpsTronic.monitor=true and forwards logs to the OpsTronic backend.
#
# Build & publish (maintainer only):
#   docker build -f Dockerfile.agent -t OpsTronic/agent:latest .
#   docker push OpsTronic/agent:latest
#
# User usage (one-liner):
#   docker run -d \
#     -e OPSTRON_API_KEY=your_key \
#     -e OPSTRON_BACKEND_URL=https://OpsTronicic.onrender.com \
#     -v /var/run/docker.sock:/var/run/docker.sock:ro \
#     --name opstronic-agent \
#     OpsTronic/agent:latest
# ============================================================================

FROM python:3.12-slim

# Metadata
LABEL maintainer="OpsTronic <hitanshu.rathi24@spit.ac.in>"
LABEL version="4.0.0"
LABEL description="OpsTronic log forwarding agent — monitors Docker containers and triggers AI-powered RCA"

# Security: run as non-root where possible
# (Docker socket access still requires the docker group)
WORKDIR /app

# Install only what the forwarder needs — keep the image tiny
RUN pip install --no-cache-dir requests==2.32.3 docker==7.1.0

# Copy only the forwarder script — nothing else
COPY opstronic_forwarder.py .

# Environment variable defaults (user must provide API_KEY)
ENV OPSTRON_BACKEND_URL="https://OpsTronicic.onrender.com" \
    OPSTRON_POLL_SECS="30" \
    OPSTRON_LABEL="OpsTronic.monitor"

# Health check — verifies the agent process is still running
HEALTHCHECK --interval=60s --timeout=10s --retries=3 \
    CMD pgrep -f opstronic_forwarder.py || exit 1

CMD ["python", "-u", "opstronic_forwarder.py"]
